{
  "schema_version": "1.0.0",
  "api": {
    "port": 54321,
    "schemas": ["public"],
    "extra_search_path": ["public", "extensions"],
    "max_rows": 1000
  },
  "db": {
    "port": 54322,
    "major_version": 15,
    "seed_file": "seed.sql"
  },
  "realtime": {
    "enabled": true,
    "max_bytes_per_second": 1000000,

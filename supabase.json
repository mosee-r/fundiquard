    "max_payload_bytes": 131072,
    "timeout_sec": 3600,
    "ssl_enforce": false
  },
  "analytics": {
    "enabled": false,
    "port": 4000,
    "vector_port": 3327,
    "pg_meta_port": 5555
  },
  "auth": {
    "enabled": true,
    "twilio_autoconfirm": false,
    "twitter_autoconfirm": false
  },
  "storage": {
    "file_size_limit": 52428800
  },
  "functions": [
    {
      "slug": "auth",
      "verify_jwt": false
    },
    {
      "slug": "jobs",
      "verify_jwt": true
    },
    {
      "slug": "bids",
      "verify_jwt": true
